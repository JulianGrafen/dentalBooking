# Canonical site URL (booking links). Defaults to https://teeth.al.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Server-only. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Resend — transactional email (appointment confirm/cancel/reschedule)
# Sandbox: onboarding@resend.dev only delivers to your Resend account email.
# Production: verify your domain at resend.com/domains, then use e.g.:
# EMAIL_FROM=teeth.al <noreply@teeth.al>
RESEND_API_KEY=<resend-api-key>
EMAIL_FROM=teeth.al <onboarding@resend.dev>
